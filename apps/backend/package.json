{
  "name": "@repo/backend",
  "version": "1.0.0",
  "description": "Express API backend for ERP",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "start:worker": "node dist/worker.js",
    "check-types": "tsc --noEmit",
    "lint": "eslint .",
    "test": "node --import tsx --test \"src/**/*.test.ts\""
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1050.0",
    "@aws-sdk/s3-request-presigner": "^3.1050.0",
    "@prisma/adapter-pg": "^7.2.0",
    "@repo/auth-config": "workspace:*",
    "@repo/db": "workspace:*",
    "better-auth": "^1.2.0",
    "bullmq": "^5.76.10",
    "cors": "^2.8.6",
    "csv-parse": "^5.6.0",
    "dotenv": "^16.5.0",
    "express": "^5.2.1",
    "jose": "^6.1.3",
    "multer": "^2.1.1",
    "resend": "^6.12.3",
    "zod": "^4.3.6",
    "zod-express-middleware": "^1.4.0"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.15.3",
    "eslint": "^9.39.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
