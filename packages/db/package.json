    "pg": "^8.18.0"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/pg": "^8.16.0",
    "eslint": "^9.39.1",
    "typescript": "^5.9.3",
    "prisma": "7.4.1",
    "rimraf": "^5.0.5",
    "tsx": "4.21.0"
  }
