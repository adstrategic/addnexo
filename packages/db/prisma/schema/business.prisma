// Self-registration invite: one row per magic link, discriminated by `modulo`.
// Module-specific defaults live in `defaultsJson` (see backend registro-invite/defaults/*).
enum RegistroInvitacionModulo {
  CLIENTE
  PROVEEDOR
  VENDEDOR

  @@schema("business")
}

model RegistroInvitacion {
  id               String                   @id @default(cuid())
  tokenHash        String                   @unique
  organizationId   String
  modulo           RegistroInvitacionModulo
  expiresAt        DateTime
  usedAt           DateTime?
  createdAt        DateTime                 @default(now())
  createdByUsuario String                   @db.VarChar(100)

  invitedEmail String?

  /// JSON snapshot merged on submit (shape depends on `modulo`).
  defaultsJson Json

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, modulo, usedAt])
  @@map("registro_invitacion")
  @@schema("business")
}

