// ===============================================
// BUSINESS SCHEMA (ERP models, enums, dashboard)
// ===============================================
// Location, inventory, orders, invoices, payments, etc.

// ===============================================
// TABLAS DE UBICACIÓN GEOGRÁFICA
// ===============================================

model Pais {
  id             Int     @id @default(autoincrement())
  organizationId String?
  nombre         String
  codigo         String

  // Relaciones
  estados    Estado[]
  acumulados AcumuladoPais[]
  invcaruni  Invcaruni[]

  Organization Organization? @relation(fields: [organizationId], references: [id])

  @@map("paises")
  @@schema("business")
}

model Estado {
  id             Int     @id @default(autoincrement())
  organizationId String?
  paisId         Int
  nombre         String

  // Relaciones
  pais         Pais              @relation(fields: [paisId], references: [id])
  ciudades     Ciudad[]
  acumulados   AcumuladoEstado[]
  Organization Organization?     @relation(fields: [organizationId], references: [id])

  @@unique([nombre, paisId], name: "nombre_paisId")
  @@map("estados")
  @@schema("business")
}

model Ciudad {
  id             Int     @id @default(autoincrement())
  organizationId String?
  estadoId       Int
  nombre         String

  // Relaciones
  estado       Estado        @relation(fields: [estadoId], references: [id])
  Organization Organization? @relation(fields: [organizationId], references: [id])

  acumulados                  AcumuladoCiudad[]
  Mproved                     Mproved[]
  clientes                    Cltemae[]
  // almacenes   Almacen[]
  Pclteg                      Pclteg[]
  comprasProveedor            Proved[]
  ActivatedOrganizationCiudad OrganizationCiudad[]
  Almacen                     Almacen[]
  KardexLote                  KardexLote[]
  Movkar                      Movkar[]
  KardexDet                   KardexDet[]
  Facturag                    Facturag[]
  dispatchOrderGs             DispatchOrderG[]

  @@unique([nombre, estadoId], name: "nombre_estadoId")
  @@map("ciudades")
  @@schema("business")
}

model OrganizationCiudad {
  organizationId String
  ciudadId       Int

  // Relaciones
  organization Organization @relation(fields: [organizationId], references: [id])
  ciudad       Ciudad       @relation(fields: [ciudadId], references: [id])

  // Clave primaria compuesta para asegurar una única entrada por org/ciudad
  @@id([organizationId, ciudadId])
  @@map("organization_ciudad")
  @@schema("business")
}

// ===============================================
// TABLAS DE ACUMULADOS POR UBICACIÓN
// ===============================================

model AcumuladoPais {
  id             Int    @id @default(autoincrement())
  organizationId String
  paisId         Int
  mes            Int    @db.SmallInt // 1-12
  ano            Int    @db.SmallInt

  // Métricas de negocio
  acumuladoCompras Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones
  pais         Pais         @relation(fields: [paisId], references: [id])
  Organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([paisId, mes, ano])
  @@map("acumulados_pais")
  @@schema("business")
}

model AcumuladoEstado {
  id             Int    @id @default(autoincrement())
  organizationId String

  estadoId Int
  mes      Int @db.SmallInt // 1-12
  ano      Int @db.SmallInt

  // Métricas de negocio
  acumuladoCompras Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones
  estado       Estado       @relation(fields: [estadoId], references: [id])
  Organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([estadoId, mes, ano])
  @@map("acumulados_estado")
  @@schema("business")
}

model AcumuladoCiudad {
  id             Int    @id @default(autoincrement())
  organizationId String
  ciudadId       Int

  mes Int @db.SmallInt // 1-12
  ano Int @db.SmallInt

  // Métricas de negocio
  acumuladoCompras Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones
  ciudad       Ciudad       @relation(fields: [ciudadId], references: [id])
  Organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([ciudadId, mes, ano])
  @@map("acumulados_ciudad")
  @@schema("business")
}

// TODO: agregar campo de creadoOModificado y usuario

model UnidadMedida {
  UMId             Int    @id @default(autoincrement())
  UMOrganizationId String

  UMNombre       String
  UMDescripcion  String @db.VarChar(30)
  UMOrgSecuencia Int

  // Auditoria:
  creadoOModificado DateTime @default(now())
  usuario           String   @db.VarChar(50)

  organization Organization @relation(fields: [UMOrganizationId], references: [id])

  invcaruni Invcaruni[]

  @@unique([UMOrganizationId, UMOrgSecuencia])
  @@map("unidades_medida")
  @@schema("business")
}

// Modelo para las clasificaciones de almacenes (CLASEALM)
model ClaseAlmacen {
  CAId             Int    @id @default(autoincrement())
  CAOrganizationId String

  CACodigo      String @db.VarChar(1)
  CADescripcion String @db.VarChar(20)

  // Relaciones
  organization Organization @relation(fields: [CAOrganizationId], references: [id])
  // almacenes    Almacen[] // Una clase puede tener muchos almacenes

  @@unique([CAOrganizationId, CACodigo])
  @@map("clases_almacen")
  @@schema("business")
}

model Almacen {
  ALId             Int    @id @default(autoincrement())
  ALOrganizationId String
  // ALClaseId        Int
  ALCiudadId       Int

  // codigo         String @db.VarChar(3)
  ALNombre         String
  ALResponsable    String
  ALDireccion      String
  ALTelefono       String
  ALCuentaContable String @default("")
  ALOrgSecuencia   Int

  // Auditoria
  creadoOModificado DateTime @default(now())
  usuario           String

  // Relaciones
  organization Organization @relation(fields: [ALOrganizationId], references: [id])
  ciudad       Ciudad       @relation(fields: [ALCiudadId], references: [id])

  kardex     Kardex[]
  pdsucu     Pdsucu[]
  // pedidosSucursal PDSUCU[]
  // ClaseAlmacen ClaseAlmacen @relation(fields: [ALClaseId], references: [CAId])
  Movkar     Movkar[]
  KardexLote KardexLote[]
  KardexDet  KardexDet[]

  // @@unique([organizationId, codigo])
  @@unique([ALOrganizationId, ALOrgSecuencia])
  @@map("almacenes")
  @@schema("business")
}

// 23. PDSUCU - Pedidos de Sucursales
model Pdsucu {
  PSId             Int    @id @default(autoincrement())
  PSOrganizationId String
  PSAlmacenId      Int
  PSInvcaruniId    Int

  PSCantidadPedida     Decimal
  PSCantidadEntregada  Decimal
  PSValorUnitario      Decimal  @db.Decimal(11, 3)
  PSAProbado           Boolean
  PSPedido             String   @db.VarChar(5)
  PSFechaPedido        DateTime @db.Date
  PSFechaUltimaEntrega DateTime @db.Date
  PSOrgSecuencia       Int

  almacen      Almacen      @relation(fields: [PSAlmacenId], references: [ALId])
  Invcaruni    Invcaruni    @relation(fields: [PSInvcaruniId], references: [CKId])
  organization Organization @relation(fields: [PSOrganizationId], references: [id])

  @@unique([PSOrganizationId, PSOrgSecuencia])
  @@map("pedidos_sucursal")
  @@schema("business")
}

model Invcaruni {
  CKId             Int    @id @default(autoincrement())
  CKGrupoId        Int
  CKOrganizationId String
  CKUnidadMedidaId Int

  // CKGrupo  Int
  // CKGrupo  Decimal @db.Decimal(3, 0)
  // CKCodigo Decimal @db.Decimal(5, 0)
  // CKUnidad               Decimal @db.Decimal(3, 0)
  // digitoChequeo  Int     @db.SmallInt

  CKCodigo               Int
  CKDescripcion          String  @db.VarChar(40)
  CKOrigenId             Int
  CKPrecioPublico        Decimal @db.Decimal(9, 2)
  CKPrecioVenta1         Decimal @db.Decimal(9, 2)
  CKPrecioVenta2         Decimal @db.Decimal(9, 2)
  CKPorcenMargen         Decimal @db.Decimal(4, 2)
  CKPorcenMargenTopeDesc Decimal @default(0) @db.Decimal(4, 2)
  CKTopeDescuento        Decimal @default(0) @db.Decimal(9, 2)
  CKIva                  Decimal @default(0) @db.Decimal(4, 2)
  CKPesoPromedioKg       Decimal @default(0) @db.Decimal(9, 2)
  CKExento               Boolean @default(false)
  CKOrgSecuencia         Int

  // Auditoria
  creadoOModificado DateTime @default(now())
  usuario           String   @db.VarChar(50)

  organization   Organization @relation(fields: [CKOrganizationId], references: [id])
  grupo          Invgrupos    @relation(fields: [CKGrupoId], references: [GId])
  unidadDeMedida UnidadMedida @relation(fields: [CKUnidadMedidaId], references: [UMId])
  origenPais     Pais         @relation(fields: [CKOrigenId], references: [id])

  proved   Proved[]
  pclteu   Pclteu[]
  facturau Facturau[]
  kardex   Kardex[]
  pdsucu   Pdsucu[]

  // cambiosPrecios   CTPRECAR[]
  Movkar                Movkar[]
  KardexLote            KardexLote[]
  KardexDet             KardexDet[]
  dispatchOrderUs       DispatchOrderU[]
  inventoryReservations InventoryReservation[]

  // @@unique([CKGrupo, CKCodigo])
  @@unique([CKOrganizationId, CKGrupoId, CKCodigo])
  @@unique([CKOrganizationId, CKOrgSecuencia])
  @@index([CKOrganizationId, CKDescripcion])
  @@index([CKOrganizationId, CKOrigenId])
  @@map("invcaruni")
  @@schema("business")
}

// 4. GRUPOS - Grupos de Inventario
model Invgrupos {
  GId             Int    @id @default(autoincrement())
  GOrganizationId String

  // nro            Decimal @unique @db.Decimal(3, 0) // 001-999
  GNro          Int // 001-999
  GDescripcion  String @db.VarChar(30)
  GOrgSecuencia Int

  // Auditoria
  creadoOModificado DateTime @default(now())
  usuario           String   @db.VarChar(50)

  organization Organization @relation(fields: [GOrganizationId], references: [id])

  invcaruni Invcaruni[]

  @@unique([GNro, GOrganizationId])
  @@unique([GOrganizationId, GOrgSecuencia])
  @@map("grupos")
  @@schema("business")
}

// 5. KARDEX - Control de Inventario
// 1. KARDEX - Tabla padre (nivel producto-almacén)
model Kardex {
  KId             Int    @id @default(autoincrement())
  KInvcaruniId    Int
  KOrganizationId String
  KAlmacenId      Int

  KExistenciaInicial   Decimal   @default(0) @db.Decimal(9, 2)
  KEntradas            Decimal   @default(0) @db.Decimal(7, 2)
  KValorEntradas       Decimal   @default(0) @db.Decimal(9, 2)
  KSalidas             Decimal   @default(0) @db.Decimal(7, 2)
  KValorSalidas        Decimal   @default(0) @db.Decimal(9, 2)
  KExistenciaFin       Decimal   @default(0) @db.Decimal(9, 2)
  KCostoUltimo         Decimal   @default(0) @db.Decimal(9, 2)
  KCostoPromedio       Decimal   @default(0) @db.Decimal(9, 2)
  KLValorCostoUltimo   Decimal   @default(0) @db.Decimal(9, 2)
  KLValorCostoPromedio Decimal   @default(0) @db.Decimal(9, 2)
  KFechaUltimoConteo   DateTime? @db.Date
  KUltimoConteo        Decimal?  @default(0) @db.Decimal(9, 2)
  KMes                 Int       @db.SmallInt
  KAno                 Int       @db.SmallInt

  KExistenciaMin    Int    @default(0)
  KExistenciaMax    Int    @default(0)
  KTiempoReposicion Int    @default(0)
  KNroTarjeta       String @db.VarChar(6)
  KUltimoDetalle    String @db.VarChar(20)
  KOrgSecuencia     Int

  // Auditoria
  creadoOModificado DateTime @default(now())
  usuario           String   @db.VarChar(50)

  // Relaciones
  invcaruni    Invcaruni    @relation(fields: [KInvcaruniId], references: [CKId])
  organization Organization @relation(fields: [KOrganizationId], references: [id])
  almacen      Almacen      @relation(fields: [KAlmacenId], references: [ALId])

  // Hijos
  kardexLotes KardexLote[]
  paprovee    Paprovee[]
  rotado      Rotado[]
  karrev      Karrev[]

  // CONSTRAINT PRINCIPAL: Replica KTORGANIZACION + KTID + KTGRUPO + KTCODIGO
  // En nuestro caso: ORGANIZACION + PRODUCTO + ALMACEN (GRUPO y CODIGO están en el producto)
  @@unique([KOrganizationId, KInvcaruniId, KAlmacenId, KMes, KAno], name: "kardex_business_key")
  @@unique([KOrganizationId, KOrgSecuencia], name: "kardex_sequence")
  @@index([KOrganizationId, KExistenciaFin])
  @@map("kardex")
  @@schema("business")
}

// 2. KARDEX_LOTE - Nivel intermedio (producto-almacén-lote-ciudad)
// AQUÍ VA ciudadId porque el lote está asociado a una ciudad específica
model KardexLote {
  KLId             Int    @id @default(autoincrement())
  KLKardexId       Int // Solo referencia al padre
  KLCiudadId       Int // ÚNICA ubicación donde debe estar ciudadId
  KLOrganizationId String
  KLInvcaruniId    Int
  KAlmacenId       Int

  KLLote               String
  KLNroDocumento       String    @db.VarChar(50) // Document number to differentiate lots
  KLExistenciaInicial  Decimal   @default(0) @db.Decimal(9, 2)
  KLEntradas           Decimal   @default(0) @db.Decimal(7, 2)
  KLValorEntradas      Decimal   @default(0) @db.Decimal(9, 2)
  KLSalidas            Decimal   @default(0) @db.Decimal(7, 2)
  KLValorSalidas       Decimal   @default(0) @db.Decimal(9, 2)
  KLExistenciaFin      Decimal   @default(0) @db.Decimal(9, 2)
  KLCostoUltimo        Decimal   @default(0) @db.Decimal(9, 2)
  KLCostoPromedio      Decimal   @default(0) @db.Decimal(9, 2)
  KLValorCostoUltimo   Decimal   @default(0) @db.Decimal(9, 2)
  KLValorCostoPromedio Decimal   @default(0) @db.Decimal(9, 2)
  KLFechaUltimaEntrada DateTime? @db.Date
  KLFechaUltimoConteo  DateTime? @db.Date
  KLUltimoConteo       Decimal?  @default(0) @db.Decimal(9, 2)
  KLMes                Int       @db.SmallInt
  KLAno                Int       @db.SmallInt

  // Auditoria
  creadoOModificado DateTime @default(now())
  usuario           String   @db.VarChar(50)

  // Relaciones - Solo las necesarias
  kardex       Kardex       @relation(fields: [KLKardexId], references: [KId])
  ciudad       Ciudad       @relation(fields: [KLCiudadId], references: [id])
  organization Organization @relation(fields: [KLOrganizationId], references: [id])
  invcaruni    Invcaruni    @relation(fields: [KLInvcaruniId], references: [CKId])
  almacen      Almacen      @relation(fields: [KAlmacenId], references: [ALId])

  // Hijos
  kardexDet             KardexDet[]
  inventoryReservations InventoryReservation[]

  // CONSTRAINT PRINCIPAL: Replica KLORGANIZACION + KLID + KLGRUPO + KLCODIGO + KLORIGENPAIS + KLLOTE
  // En nuestro caso: ORGANIZACION + PRODUCTO + ALMACEN + CIUDAD + LOTE + DOCUMENTO
  @@unique([KLKardexId, KLCiudadId, KLLote, KLNroDocumento, KLMes, KLAno], name: "kardex_lote_business_key")
  @@index([KLExistenciaFin])
  @@map("kardex_lote")
  @@schema("business")
}

// 3. KARDEX_DET - Nivel más específico (por fecha)
// SIN ciudadId - se obtiene a través de KardexLote
model KardexDet {
  KDId             Int    @id @default(autoincrement())
  KDKardexLoteId   Int // Solo referencia al padre KardexLote
  KDOrganizationId String
  KDAlmacenId      Int
  KDInvcaruniId    Int
  KDCiudadId       Int
  KDLote           String // Denormalized lot ref (matches KardexLote.KLLote)

  KDFecha             DateTime @db.Date
  KDExistenciaInicial Decimal  @default(0) @db.Decimal(9, 2)
  KDEntradas          Decimal  @default(0) @db.Decimal(7, 2)
  KDValorEntradas     Decimal  @default(0) @db.Decimal(9, 2)
  KDSalidas           Decimal  @default(0) @db.Decimal(7, 2)
  KDValorSalidas      Decimal  @default(0) @db.Decimal(9, 2)
  KDExistenciaFin     Decimal  @default(0) @db.Decimal(9, 2)
  KDCostoUltimo       Decimal  @default(0) @db.Decimal(9, 2)
  KDCostoPromedio     Decimal  @default(0) @db.Decimal(9, 2)
  KDMes               Int      @db.SmallInt
  KDAno               Int      @db.SmallInt

  creadoOModificado DateTime @default(now())
  usuario           String   @db.VarChar(50)

  // Relaciones - Solo la necesaria
  kardexLote   KardexLote   @relation(fields: [KDKardexLoteId], references: [KLId])
  organization Organization @relation(fields: [KDOrganizationId], references: [id])
  invcaruni    Invcaruni    @relation(fields: [KDInvcaruniId], references: [CKId])
  almacen      Almacen      @relation(fields: [KDAlmacenId], references: [ALId])
  ciudad       Ciudad       @relation(fields: [KDCiudadId], references: [id])

  // Hijos
  movkar Movkar[]

  // CONSTRAINT OPTIMIZADO: KDKardexLoteId ya contiene toda la jerarquía
  // Solo necesitamos agregar KDFecha para garantizar unicidad por fecha
  @@unique([KDKardexLoteId, KDFecha, KDMes, KDAno], name: "kardex_det_fecha_key")
  // INDICES DE PERFORMANCE para queries directas
  @@index([KDFecha], name: "idx_kardex_det_fecha")
  @@map("kardex_det")
  @@schema("business")
}

// 4. MOVKAR - Movimientos individuales (nivel transacción)
model Movkar {
  MVId               Int    @id @default(autoincrement())
  MVKardexDetId      Int // Solo referencia al padre KardexDet
  MVTipoMovimientoId Int
  MVLote             String // Lot identifier (purchase order ref / same concept)
  MVLoteNroDocumento String
  MVProveedorId      Int?
  MVClienteId        Int?
  MVAlmacenId        Int
  MVInvcaruniId      Int
  MVOrganizationId   String
  MVCiudadId         Int

  MVSecuencial          Int
  MVFecha               DateTime @db.Date
  MVNroDocumento        String
  MVCantidad            Decimal  @db.Decimal(7, 0)
  MVCostoSalida         Decimal? @db.Decimal(9, 2)
  MVCostoUltimo         Decimal  @db.Decimal(9, 2)
  MVCostoPrecio         Decimal  @db.Decimal(9, 2)
  MVDescuento           Decimal  @db.Decimal(6, 2)
  MVImpuesto            Decimal  @db.Decimal(6, 2)
  MVEsCostoTemporalCero Boolean  @default(false)
  MVOrgSecuencia        Int

  // Auditoria
  creadoOModificado DateTime @default(now())
  usuario           String   @db.VarChar(50)

  // Relaciones - Optimizadas
  kardexDet    KardexDet    @relation(fields: [MVKardexDetId], references: [KDId])
  tmovkar      Tmovkar      @relation(fields: [MVTipoMovimientoId], references: [TId])
  mproved      Mproved?     @relation(fields: [MVProveedorId], references: [MPId], onDelete: Restrict)
  cltemae      Cltemae?     @relation(fields: [MVClienteId], references: [CId], onDelete: Restrict)
  organization Organization @relation(fields: [MVOrganizationId], references: [id])
  invcaruni    Invcaruni    @relation(fields: [MVInvcaruniId], references: [CKId])
  almacen      Almacen      @relation(fields: [MVAlmacenId], references: [ALId])
  ciudad       Ciudad       @relation(fields: [MVCiudadId], references: [id])

  // NOTA: MVSecuencial único por organización ya garantiza unicidad total
  // No necesitamos constraint operacional adicional - Performance optimizado

  // CONSTRAINTS OPTIMIZADOS:
  // 1. URL/API: Secuencia única para referencias externas
  @@unique([MVOrganizationId, MVOrgSecuencia], name: "movkar_sequence_key")
  // 2. BUSINESS: Secuencial único por organización (COBOL compatible)
  @@unique([MVOrganizationId, MVSecuencial], name: "movkar_business_sequence")
  // INDICES DE PERFORMANCE para queries directas
  @@index([MVTipoMovimientoId, MVFecha], name: "idx_movkar_tipo_fecha")
  @@index([MVTipoMovimientoId, MVNroDocumento], name: "idx_movkar_tipo_doc")
  @@index([MVOrganizationId, MVFecha], name: "idx_movkar_org_fecha")
  @@index([MVOrganizationId, MVInvcaruniId, MVAlmacenId], name: "idx_movkar_org_inventario")
  @@map("movkar")
  @@schema("business")
}

enum TipoPropositoMovkar {
  DISPATCH_ORDER
  DISPATCH_ORDER_DEVOLUCION
  DISPATCH_ORDER_ANULACION
  FACTURA_DEVOLUCION
  NOTA_CREDITO
  NOTA_CREDITO_CON_DEVOLUCION
  NOTA_DEBITO
  ABONO

  @@schema("business")
}

// 17. TMOVKAR - Tipos de Movimiento
model Tmovkar {
  TId             Int    @id @default(autoincrement())
  TOrganizationId String

  TProposito        TipoPropositoMovkar?
  TTipo             Int
  TClase            Int
  TDescripcion      String               @db.VarChar(30)
  TAbreviatura      String               @db.VarChar(10)
  TValor            Int
  TAjusteInventario Boolean              @default(false)
  TAfecta           Boolean              @default(true)
  TRequiere         Boolean              @default(false)
  TPedido           Boolean              @default(false)
  TFactura          Boolean              @default(false)
  TProv             Boolean              @default(false)
  TCliente          Boolean              @default(false)
  TRecalcular       Boolean              @default(false)
  TOrgSecuencia     Int

  // Auditoria
  creadoOModificado DateTime @default(now())
  usuario           String   @db.VarChar(50)

  organization Organization @relation(fields: [TOrganizationId], references: [id])

  movkar         Movkar[]
  dispatchOrderU DispatchOrderU[]
  movCXC         MovCXC[]

  @@unique([TOrganizationId, TOrgSecuencia])
  @@unique([TOrganizationId, TProposito])
  @@unique([TOrganizationId, TTipo, TClase])
  @@map("tmovkar")
  @@schema("business")
}

// 10. ROTADO - Rotación de Inventario
model Rotado {
  RId             Int     @id @default(autoincrement())
  ROrganizationId String
  RInvcaruniId    Int
  RKardexId       Int
  // RGrupo       Decimal  @db.Decimal(3, 0)
  // RCodigo      Int
  RTipoIO         Decimal @db.Decimal(1, 0)
  RClase          Decimal @db.Decimal(1, 0)
  RMes            Int     @db.SmallInt
  RAno            Int     @db.SmallInt
  RMesCantidad    Decimal @db.Decimal(9, 2)
  RMesPrecio      Decimal @db.Decimal(9, 2)
  RMesCosto       Decimal @db.Decimal(9, 2)
  RAnoCantidad    Decimal @db.Decimal(9, 2)
  RAnoPrecio      Decimal @db.Decimal(9, 2)
  RAnoCosto       Decimal @db.Decimal(9, 2)
  ROrgSecuencia   Int

  // Auditoria
  creadoOModificado DateTime @default(now())
  usuario           String   @db.VarChar(50)

  organization Organization @relation(fields: [ROrganizationId], references: [id])
  kardex       Kardex       @relation(fields: [RKardexId], references: [KId])

  // @@id([RGrupo, RCodigo, RTipoIO, RClase])
  @@unique([ROrganizationId, ROrgSecuencia])
  @@map("rotado")
  @@schema("business")
}

// 19. KARREV - Reservas de Kardex
model Karrev {
  RKId             Int      @id @default(autoincrement())
  RKKardexId       Int
  RKOrganizationId String
  // Consecutivo de 3 cifras
  // RKSecuencial Int      @default(autoincrement())
  // RKGrupo      Decimal  @db.Decimal(3, 0)
  // RKCodigo     Int
  // TODO: daemon function to validate date
  RKCantidad       Decimal  @db.Decimal(9, 2)
  RKCaracter       Boolean
  RKFecha          DateTime @db.Date
  RKOrgSecuencia   Int

  // Auditoria
  creadoOModificado DateTime @default(now())
  usuario           String   @db.VarChar(50)

  kardex       Kardex       @relation(fields: [RKKardexId], references: [KId])
  organization Organization @relation(fields: [RKOrganizationId], references: [id])

  // @@id([RKGrupo, RKCodigo])
  @@unique([RKOrganizationId, RKOrgSecuencia])
