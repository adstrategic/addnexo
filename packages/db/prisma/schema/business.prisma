// Enum for invoice state
enum EstadoDispatchOrder {
  DRAFT // Borrador
  EMITTED // Emitido (inventario descargado, mercancía en tránsito)
  INVOICED // Facturado (se convirtió en factura, ya no es dispatch order)
  DISPATCHED
  ANULATED // Anulado (was CANCELLED)

  @@schema("business")
}

enum EstadoReserva {
  ACTIVE // Reserva activa
  EXPIRED // Expirada (liberada automáticamente)
  RELEASED // Liberada manualmente
  CONSUMED // Consumida (dispatch emitido/facturado)

  @@schema("business")
}

enum ModoSalida {
  MANUAL // manual o automatico
  AUTOMATICO // automatico

  @@schema("business")
}

enum DocumentType {
  DISPATCH_ORDER
  PURCHASE_ORDER
  INVOICE

  @@schema("business")
}

// Unified Documents Model
model Document {
  DOCId               Int          @id @default(autoincrement())
  DOCOrganizationId   String
  DOCDocumentType     DocumentType
  DOCDocumentId       Int // ID of the related document (dispatch order, purchase order, or invoice)
  DOCFileName         String // System-generated name following convention
  DOCOriginalFileName String // Original uploaded filename
  DOCFileKey          String // S3 key
  DOCFileSize         Int // Size in bytes
  DOCMimeType         String // image/png, image/jpeg, application/pdf
  DOCUploadedAt       DateTime     @default(now())
  DOCUploadedBy       String       @db.VarChar(50) // Usuario que subió

  // Relations
  organization Organization @relation(fields: [DOCOrganizationId], references: [id])

  @@index([DOCOrganizationId, DOCDocumentType, DOCDocumentId])
  @@index([DOCOrganizationId, DOCDocumentType])
  @@map("documents")
  @@schema("business")
}

enum OutboxStatus {
  PENDING
  PROCESSING
  PROCESSED
  FAILED

  @@schema("business")
}

enum OutboxEventType {
  INVOICE_CREATED
  DISPATCH_ORDER_EMITTED

  @@schema("business")
}

enum AggregateType {
  FACTURA
  DISPATCH_ORDER

  @@schema("business")
}

// Transactional Outbox Pattern - Events for async processing
model OutboxEvent {
  id             Int             @id @default(autoincrement())
  organizationId String
  eventType      OutboxEventType // 'INVOICE_CREATED', 'DISPATCH_ORDER_EMITTED', etc.
  aggregateType  AggregateType // 'FACTURA', 'DISPATCH_ORDER'
  aggregateId    Int // FGId or DOGId
  payload        Json? // Optional extra data (secuencia, clienteEmail, nro)
  status         OutboxStatus    @default(PENDING) // PENDING, PROCESSING, PROCESSED, FAILED
  attempts       Int             @default(0)
  maxAttempts    Int             @default(3)
  lastError      String?         @db.Text
  processAfter   DateTime        @default(now()) // For delayed/retry scheduling
  createdAt      DateTime        @default(now())
  processedAt    DateTime?

  // Step tracking for idempotency
  s3Uploaded Boolean @default(false)
  emailSent  Boolean @default(false)

  // Email tracking improvements
  emailSkipped Boolean @default(false) // True if all emails had permanent failures
  emailResults Json? // Per-email results: { sent: [], permanentFailed: [] }

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([status, processAfter])
  @@index([organizationId, eventType])
  @@map("outbox_events")
  @@schema("business")
}

