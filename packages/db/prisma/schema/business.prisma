// 25. FACTURAG - Facturas General
model DispatchOrderG {
  DOGId              Int    @id @default(autoincrement())
  DOGOrganizationId  String
  DOGPurchaseOrderId Int?
  DOGVendedorId      Int
  DOGClienteId       Int
  DOGCiudadId        Int

  // Numeración
  // DOGNro              Decimal  @db.Decimal(6, 0)
  DOGNro           Int
  DOGOrgSecuencia  Int
  DOGPurchaseOrder String?

  // Información comercial
  DOGTipo            Int     @db.SmallInt
  DOGZona            Int     @db.SmallInt
  DOGValorTotalNeto  Decimal @db.Decimal(9, 2)
  DOGValorTotalBruto Decimal @db.Decimal(9, 2)
  DOGTotalDescuento  Decimal @db.Decimal(9, 2)
  DOGTotalIVA        Decimal @db.Decimal(9, 2)
  DOGPesoTotalKg     Decimal @default(0) @db.Decimal(9, 3)
  // DOGCostoPromedio   Decimal  @db.Decimal(9, 2)

  // Estados y aprobaciones
  DOGEstado                          EstadoDispatchOrder @default(DRAFT)
  DOGAprobado                        String              @db.VarChar(5)
  DOGDespachado                      String              @db.VarChar(5)
  /// After a return on EMITTED, warehouse PDF/email must be refreshed before dispatch.
  DOGEmittedPdfNeedsWarehouseRefresh Boolean             @default(false)

  // Fechas del ciclo de vida
  DOGFechaCreado      DateTime  @db.Date
  DOGFechaEmision     DateTime?
  DOGFechaDespacho    DateTime?
  DOGFechaFacturacion DateTime?

  // Información de contacto y entrega
  DOGTelefono1        String
  DOGTelefono2        String?
  DOGCorreo1          String
  DOGCorreo2          String?
  DOGDireccionEntrega String  @db.VarChar(50)

  // Condiciones comerciales
  DOGCondicion1 String? @db.VarChar(40)
  DOGCondicion2 String? @db.VarChar(40)
  DOGCondicion3 String? @db.VarChar(40)

  // Auditoria:
  creadoOModificado DateTime @default(now())
  usuario           String   @db.VarChar(50) // Usuario de Keycloak

  // pedido       PCLTEG?      @relation(fields: [pedidoId], references: [id])
  // Relaciones
  organization Organization @relation(fields: [DOGOrganizationId], references: [id])
  cltemae      Cltemae      @relation(fields: [DOGClienteId], references: [CId])
  vendedor     Vendedor     @relation(fields: [DOGVendedorId], references: [VId])
  ciudad       Ciudad       @relation(fields: [DOGCiudadId], references: [id])

  dispatchOrderU DispatchOrderU[]
  facturag       Facturag?
  // dispatchOrderDocuments DispatchOrderDocument[]

  @@unique([DOGOrganizationId, DOGOrgSecuencia])
  @@unique([DOGOrganizationId, DOGNro])
  @@index([DOGEstado])
  @@index([DOGOrganizationId, DOGEstado])
  @@map("dispatch_order_g")
  @@schema("business")
}

// 24. FACTURAU - Facturas Detalle
model DispatchOrderU {
  DOUId               Int        @id @default(autoincrement())
  DOUOrganizationId   String
  DOUDispatchOrderGId Int
  DOUOriginalItemId   Int?
  DOUInvcaruniId      Int
  DOUTipoMovimientoId Int
  DOUModoSalida       ModoSalida @default(AUTOMATICO)

  DOUNro           Int
  DOUCantidad      Decimal @db.Decimal(9, 2)
  DOUDescuento     Decimal @db.Decimal(9, 2)
  DOUVrNeto        Decimal @db.Decimal(9, 2)
  DOUVrBruto       Decimal @db.Decimal(9, 2)
  DOUVrUnitario    Decimal @db.Decimal(9, 2)
  DOUDetalle       String
  DOUTieneImpuesto Boolean @default(false)
  DOUReservado     Boolean @default(false)
  DOUCostoPromedio Decimal @db.Decimal(9, 2)
  DOUPesoTotalKg   Decimal @default(0) @db.Decimal(9, 3)
  DOULote          String // Lot / purchase-order id (matches KardexLote.KLLote)
  DOUNroDocumento  String  @db.VarChar(50) // Document number for lot lookup (composite key with DOULote)

  // Auditoria
  creadoOModificado DateTime @default(now())
  usuario           String   @db.VarChar(50)

  // Relaciones
  organization          Organization           @relation(fields: [DOUOrganizationId], references: [id])
  dispatchOrderG        DispatchOrderG         @relation(fields: [DOUDispatchOrderGId], references: [DOGId])
  originalDispatchItem  DispatchOrderU?        @relation("DispatchOrderUReturns", fields: [DOUOriginalItemId], references: [DOUId])
  returnDispatchItems   DispatchOrderU[]       @relation("DispatchOrderUReturns")
  invcaruni             Invcaruni              @relation(fields: [DOUInvcaruniId], references: [CKId])
  tipoMovimiento        Tmovkar                @relation(fields: [DOUTipoMovimientoId], references: [TId])
  inventoryReservations InventoryReservation[]

  @@index([DOUOrganizationId, DOUOriginalItemId])
  @@map("dispatch_order_u")
  @@schema("business")
}

