// ============================================
// MÓDULO: GESTIÓN DE PERÍODOS
// ============================================

/// Registra cada mes cerrado formalmente.
/// Una vez existe este registro, el período queda bloqueado para nuevos movimientos.
model PeriodoCierre {
  id             Int      @id @default(autoincrement())
  organizationId String
  mes            Int      @db.SmallInt // 1-12
  ano            Int      @db.SmallInt // 2-digit year (e.g. 25 = 2025)
  cerradoEn      DateTime @default(now())
  cerradoPor     String   @db.VarChar(50) // email of user who closed

  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, mes, ano])
  @@map("periodos_cierre")
  @@schema("business")
}

/// Almacena el período activo seleccionado por cada usuario (una fila por usuario-org).
/// Se usa para filtrar todos los datos de inventario por el período de trabajo elegido.
model PeriodoActivo {
  id             Int      @id @default(autoincrement())
  userId         String
  organizationId String
  mes            Int      @db.SmallInt // 1-12
  ano            Int      @db.SmallInt // 2-digit year (e.g. 25 = 2025)
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([userId, organizationId])
  @@map("periodos_activos")
  @@schema("business")
}
