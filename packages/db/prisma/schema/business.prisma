  @@index([IREstado, IRFechaExpiracion])
  @@index([IROrganizationId, IRInvcaruniId, IREstado])
  @@index([IRKardexLoteId, IREstado])
  @@map("inventory_reservations")
  @@schema("business")
}

// ============================================
// MÓDULO: FACTURAS (Invoicing)
// ============================================

// Estados de la Factura
enum EstadoFactura {
  ACTIVE // Activa
  PAID // Pagada
  OVERDUE // Vencida
  ANULATED // Anulada

  @@schema("business")
}

// Enum for payment type
enum TipoPago {
  CONTADO // Cash payment (simple)
  CANJE // Exchange/trade-in (simple)
  CREDITO // Credit payment (simple)
  WALLET // Digital wallet payment (detailed)
  CREDIT_CARD // Credit card payment (detailed)
  TRANSFER // Bank transfer payment (detailed)
  CHECK // Check payment (detailed)

  @@schema("business")
}

// 25. FACTURAG - Facturas General
model Facturag {
  FGId               Int    @id @default(autoincrement())
  FGOrganizationId   String
  FGDispatchOrderGId Int?   @unique
  FGVendedorId       Int
  FGClienteId        Int
  FGCiudadId         Int

  // Numeración fiscal
  FGNro           Int
  FGOrgSecuencia  Int
  FGPurchaseOrder String?

  // Información comercial
  // FGTipo            Int      @db.SmallInt
  // FGZona            Int      @db.SmallInt
  FGPago            TipoPago
  FGValorTotalNeto  Decimal  @db.Decimal(9, 2)
  FGValorTotalBruto Decimal  @db.Decimal(9, 2)
  FGTotalDescuento  Decimal  @db.Decimal(9, 2)
  FGTotalIVA        Decimal  @db.Decimal(9, 2)
  FGSaldo           Decimal  @db.Decimal(9, 2)
  // FGCostoPromedio   Decimal  @db.Decimal(9, 2)

  // Estados y aprobaciones
  FGEstado         EstadoFactura @default(ACTIVE)
  FGFacturaDeSaldo Boolean       @default(false)

  // Fechas del ciclo de vida
  // FGFechaEmision     DateTime? @db.Date
  // FGFechaFacturacion DateTime? @db.Date
  FGFechaCreado      DateTime  @db.Date
  FGFechaVencimiento DateTime  @db.Date // cuando vence la factura
  FGFechaPago        DateTime?

  // Información de contacto y entrega
  FGTelefono1        String
  FGTelefono2        String?
  FGCorreo1          String
  FGCorreo2          String?
  FGDireccionEntrega String  @db.VarChar(50)

  // Condiciones comerciales
  FGCondicion1 String? @db.VarChar(40)
  FGCondicion2 String? @db.VarChar(40)
  FGCondicion3 String? @db.VarChar(40)

  // Auditoria:
  creadoOModificado DateTime @default(now())
  usuario           String   @db.VarChar(50) // Usuario de Keycloak

  // pedido       PCLTEG?      @relation(fields: [pedidoId], references: [id])
  organization   Organization    @relation(fields: [FGOrganizationId], references: [id])
  dispatchOrderG DispatchOrderG? @relation(fields: [FGDispatchOrderGId], references: [DOGId])
  cltemae        Cltemae         @relation(fields: [FGClienteId], references: [CId])
  vendedor       Vendedor        @relation(fields: [FGVendedorId], references: [VId])
  ciudad         Ciudad          @relation(fields: [FGCiudadId], references: [id])

  // Detalles
  facturau Facturau[]
  movCXC   MovCXC[]

  @@unique([FGOrganizationId, FGOrgSecuencia])
  @@unique([FGOrganizationId, FGNro, FGFacturaDeSaldo])
  @@index([FGPago])
  @@index([FGEstado])
  @@index([FGOrganizationId, FGEstado])
  @@map("facturag")
  @@schema("business")
}

model MovCXC {
  MCId               Int    @id @default(autoincrement())
  MCOrganizationId   String
  MCFacturaId        Int
  MCTipoMovimientoId Int

  MCNro          Int
  MCNroDocumento String
  MCDescripcion  String
  MCValor        Decimal  @db.Decimal(9, 2)
  MCTipoPago     TipoPago
  MCFecha        DateTime @db.Date
  MCSecuencia    Int

  // Auditoria
  creadoOModificado DateTime @default(now())
  usuario           String   @db.VarChar(50)

  // Relaciones
  organization       Organization @relation(fields: [MCOrganizationId], references: [id])
  facturag           Facturag     @relation(fields: [MCFacturaId], references: [FGId])
  tipoMovimiento     Tmovkar      @relation(fields: [MCTipoMovimientoId], references: [TId])
  facturaReturnItems Facturau[]

  // Payment details relations (one-to-one, optional)
  walletPayment     WalletPayment?
  creditCardPayment CreditCardPayment?
  transferPayment   TransferPayment?
  checkPayment      CheckPayment?

  @@unique([MCOrganizationId, MCFacturaId, MCSecuencia])
  @@map("mov_cxc")
  @@schema("business")
}

// ============================================
// MÓDULO: BANKS
// ============================================

model Bank {
  BId             Int    @id @default(autoincrement())
  BOrganizationId String
  BNombre         String
  BOrgSecuencia   Int

  // Auditoria
  creadoOModificado DateTime @default(now())
  usuario           String   @db.VarChar(50)

  organization       Organization        @relation(fields: [BOrganizationId], references: [id])
  walletPayments     WalletPayment[]
  creditCardPayments CreditCardPayment[]
  transferPayments   TransferPayment[]
  checkPayments      CheckPayment[]

  @@unique([BOrganizationId, BNombre])
  @@unique([BOrganizationId, BOrgSecuencia])
  @@map("banks")
  @@schema("business")
}

// ============================================
// MÓDULO: PAYMENT DETAILS
// ============================================

// Wallet Payment Details
model WalletPayment {
  WPId             Int    @id @default(autoincrement())
  WPMovCXCId       Int    @unique
  WPOrganizationId String

  WPBancoId        Int // FK to Bank
  WPNombreWallet   String @db.VarChar(100) // Wallet name (e.g., "Zelle", "Nequi")
  WPTelefonoOClave String @db.VarChar(50) // Phone number or key

  creadoOModificado DateTime @default(now())
  usuario           String   @db.VarChar(50)

  movCXC       MovCXC       @relation(fields: [WPMovCXCId], references: [MCId], onDelete: Cascade)
  organization Organization @relation(fields: [WPOrganizationId], references: [id])
  bank         Bank         @relation(fields: [WPBancoId], references: [BId])

  @@map("wallet_payments")
  @@schema("business")
}

// Credit Card Payment Details
model CreditCardPayment {
  CCPId             Int    @id @default(autoincrement())
  CCPMovCXCId       Int    @unique
  CCPOrganizationId String

  CCPBancoId         Int // FK to Bank
  CCPMarca           String @db.VarChar(50) // Brand (Visa, Mastercard, Amex, etc.)
  CCPUltimos4Digitos String @db.VarChar(4) // Last 4 digits only

  creadoOModificado DateTime @default(now())
  usuario           String   @db.VarChar(50)

  movCXC       MovCXC       @relation(fields: [CCPMovCXCId], references: [MCId], onDelete: Cascade)
  organization Organization @relation(fields: [CCPOrganizationId], references: [id])
  bank         Bank         @relation(fields: [CCPBancoId], references: [BId])

  @@map("credit_card_payments")
  @@schema("business")
}

// Transfer Payment Details
model TransferPayment {
  TPId             Int    @id @default(autoincrement())
  TPMovCXCId       Int    @unique
  TPOrganizationId String

  TPBancoId      Int // FK to Bank
  TPTipoCuenta   String @db.VarChar(50) // Account type (Checking, Savings, etc.)
  TPNumeroCuenta String @db.VarChar(50) // Account number

  creadoOModificado DateTime @default(now())
  usuario           String   @db.VarChar(50)

  movCXC       MovCXC       @relation(fields: [TPMovCXCId], references: [MCId], onDelete: Cascade)
  organization Organization @relation(fields: [TPOrganizationId], references: [id])
  bank         Bank         @relation(fields: [TPBancoId], references: [BId])

  @@map("transfer_payments")
  @@schema("business")
}

// Check Payment Details
model CheckPayment {
  CHPId             Int    @id @default(autoincrement())
  CHPMovCXCId       Int    @unique
  CHPOrganizationId String

  CHPBancoId      Int // FK to Bank
  CHPNumeroCheque String   @db.VarChar(50) // Check number
  CHPFechaCheque  DateTime @db.Date // Check due date

  creadoOModificado DateTime @default(now())
  usuario           String   @db.VarChar(50)

  movCXC       MovCXC       @relation(fields: [CHPMovCXCId], references: [MCId], onDelete: Cascade)
  organization Organization @relation(fields: [CHPOrganizationId], references: [id])
  bank         Bank         @relation(fields: [CHPBancoId], references: [BId])

  @@map("check_payments")
  @@schema("business")
}

// 24. FACTURAU - Facturas Detalle
model Facturau {
  FUId             Int    @id @default(autoincrement())
  FUOrganizationId String
  FUFacturaId      Int
  FUOriginalItemId Int?
  FUInvcaruniId    Int

  FUNro              Int
  FUCantidad         Decimal @db.Decimal(9, 2)
  FUDescuento        Decimal @db.Decimal(9, 2)
  FUVrNeto           Decimal @db.Decimal(9, 2)
  FUVrBruto          Decimal @db.Decimal(9, 2)
  FUVrUnitario       Decimal @db.Decimal(9, 2)
  FUDetalle          String
  FUTieneImpuesto    Boolean @default(false)
  FULote             String
  FULoteNroDocumento String  @db.VarChar(50)
  FUMovCXCId         Int?
  FUCostoPromedio    Decimal @db.Decimal(9, 2)

  // Auditoria
  creadoOModificado DateTime @default(now())
  usuario           String   @db.VarChar(50)

  // Relaciones
  organization        Organization @relation(fields: [FUOrganizationId], references: [id])
  facturag            Facturag     @relation(fields: [FUFacturaId], references: [FGId])
  originalFacturaItem Facturau?    @relation("FacturauReturns", fields: [FUOriginalItemId], references: [FUId])
  returnFacturaItems  Facturau[]   @relation("FacturauReturns")
  invcaruni           Invcaruni    @relation(fields: [FUInvcaruniId], references: [CKId])
  movCXCReturn        MovCXC?      @relation(fields: [FUMovCXCId], references: [MCId])

  @@index([FUOrganizationId, FUOriginalItemId])
  @@map("facturau")
  @@schema("business")
}

// 27. RCLTEG - Remisiones Cliente General (similar a pedidos)
model Rclteg {
  RGId             Int    @id @default(autoincrement())
  RGOrganizationId String
  RGClienteId      Int

  RGVendedorId       Int?
  RGNro              Decimal  @db.Decimal(6, 0)
  RGNitCliente       BigInt
  RGPago             Int      @db.SmallInt
  RGComprador        String   @db.VarChar(30)
  RGNitCedula        Decimal  @db.Decimal(10, 3)
  RGDireccion        String   @db.VarChar(30)
  RGTipo             Int      @db.SmallInt
  RGZona             Int      @db.SmallInt
  RGAprobado         String   @db.VarChar(5)
  RGDespachado       String   @db.VarChar(5)
  RGTelefono1        Decimal  @db.Decimal(7, 3)
  RGTelefono2        Decimal  @db.Decimal(7, 3)
  RGCiudad           String   @db.VarChar(12)
  RGPedido           Decimal  @db.Decimal(6, 3)
  RGOrdenCompra      Decimal  @db.Decimal(6, 3)
  RGFechaEntrega     DateTime @db.Date
  RGFechaVencimiento DateTime @db.Date
  RGCondicion1       String   @db.VarChar(40)
  RGCondicion2       String   @db.VarChar(40)
  RGCondicion3       String   @db.VarChar(40)
  RGOrgSecuencia     Int

  // Auditoria:
  creadoOModificado DateTime @default(now())
  usuario           String   @db.VarChar(50) // Usuario de Keycloak

  organization Organization @relation(fields: [RGOrganizationId], references: [id])

  cltemae  Cltemae?  @relation(fields: [RGClienteId], references: [CId])
  vendedor Vendedor? @relation(fields: [RGVendedorId], references: [VId])

  rclteu Rclteu[]

  @@unique([RGOrganizationId, RGOrgSecuencia])
  @@index([RGNitCliente])
  @@index([RGPago])
  @@index([RGFechaEntrega])
  @@map("rclteg")
  @@schema("business")
}

// 28. RCLTEU - Remisiones Cliente Detalle
model Rclteu {
  RUId             Int    @id @default(autoincrement())
  RUOrganizationId String
  RURemisionId     Int

  RUNroRemision Decimal @db.Decimal(6, 0)
  RUSecuencia   Int     @db.SmallInt
  RUGrupo       Int     @db.SmallInt
  RUCodigo      Int
  RUCantidad    Decimal @db.Decimal(8, 3)
  RUVrUnitario  Decimal @db.Decimal(8, 3)

  // Auditoria:
  creadoOModificado DateTime @default(now())
  usuario           String   @db.VarChar(50) // Usuario de Keycloak

  organization Organization @relation(fields: [RUOrganizationId], references: [id])
  rclteg       Rclteg       @relation(fields: [RURemisionId], references: [RGId])

  @@unique([RUNroRemision, RUSecuencia])
  @@index([RUGrupo, RUCodigo, RUNroRemision])
  @@map("rclteu")
  @@schema("business")
}

