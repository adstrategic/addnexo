model InventoryReservation {
  IRId                Int           @id @default(autoincrement())
  IROrganizationId    String
  IRDispatchOrderUId  Int
  IRInvcaruniId       Int
  IRKardexLoteId      Int // Link to specific KardexLote for lote-level tracking
  IRCantidadReservada Int
  IRFechaReserva      DateTime      @db.Date
  IRFechaExpiracion   DateTime      @db.Date
  IRFechaLiberacion   DateTime?     @db.Date
  IREstado            EstadoReserva @default(ACTIVE)
  IRMotivo            String?       @db.VarChar(100)
